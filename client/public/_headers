/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), payment=(), usb=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin

# Hashed JS/CSS/image chunks — content-addressed, safe to cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML entry point — never cache; always revalidate to pick up new deployments
/
  Cache-Control: no-cache

/*.html
  Cache-Control: no-cache

# Service worker must never be served stale
/sw.js
  Cache-Control: no-cache, no-store

# Web manifest can be cached briefly
/manifest.webmanifest
  Cache-Control: public, max-age=86400
