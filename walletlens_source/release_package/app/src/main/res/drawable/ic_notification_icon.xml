    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Baseline -->
    <path android:fillColor="#FFFFFF" android:pathData="M4,20 L20,20" />
    <!-- Three bars rising from left to right -->
    <path android:fillColor="#FFFFFF" android:pathData="M6,20 L6,13 L8,13 L8,20 Z" />
    <path android:fillColor="#FFFFFF" android:pathData="M11,20 L11,9 L13,9 L13,20 Z" />
    <path android:fillColor="#FFFFFF" android:pathData="M16,20 L16,5 L18,5 L18,20 Z" />
