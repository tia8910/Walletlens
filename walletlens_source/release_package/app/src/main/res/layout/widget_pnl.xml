<?xml version="1.0" encoding="utf-8"?>
<!-- WalletLens daily P&amp;L widget — 4×2 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📊 Daily P&amp;L"
            android:textColor="#10b981"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_pnl_update"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#777777"
            android:textSize="10sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2a2a3e"
        android:layout_marginBottom="8dp" />

    <!-- Big P&amp;L number -->
    <TextView
        android:id="@+id/widget_pnl_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+$0.00"
        android:textColor="#10b981"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp" />

    <!-- P&amp;L percentage -->
    <TextView
        android:id="@+id/widget_pnl_pct"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0.00% today"
        android:textColor="#888888"
        android:textSize="13sp"
        android:layout_marginBottom="10dp" />

    <!-- Stats grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Win / Loss -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:id="@+id/widget_pnl_winners" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#10b981" android:textSize="16sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Winners" android:textColor="#888" android:textSize="10sp" />
        </LinearLayout>

        <!-- Losers -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:id="@+id/widget_pnl_losers" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#ef4444" android:textSize="16sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Losers" android:textColor="#888" android:textSize="10sp" />
        </LinearLayout>

        <!-- Best -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:id="@+id/widget_pnl_best" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="#10b981" android:textSize="12sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Best" android:textColor="#888" android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
